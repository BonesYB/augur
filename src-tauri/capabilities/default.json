{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Augur default capability: the main window plus native Open/Save dialogs and filesystem access for vaults the user explicitly picks.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:read-all",
    "fs:write-all",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": ["**"]
    }
  ]
}
